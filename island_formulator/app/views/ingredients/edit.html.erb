<% content_for :title, "Editing ingredient" %>

<div class="flex justify-center px-2">
  <div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing ingredient</h1>

  <%= render "form", ingredient: @ingredient %>

  <div class="flex justify-center gap-4 mt-4">
    <%= link_to "Show this ingredient", @ingredient, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <%= link_to "Back to ingredients", ingredients_path, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  </div>
</div>
</div>
